psych::describe(pay_clean)
## By Age group ----
pay_clean$AgeGroup = cut(pay_clean$Age, breaks = c(18, 25, 35, 45, 55, 65, Inf),
right = F,
labels = c("Under 25 years", "25-34 years", "35-44 years",
"45-54 years", "55-64 years", "Over 65 years"))
?attr()
attr(pay_clean$AgeGroup, "label") <- "Nhóm tuổi"
pay_clean |>
group_by(AgeGroup, Gender) |>
summarise(mean = mean(BasePay))
mean_base <- pay_clean |>
summarise(mean = mean(BasePay),
.by = c(AgeGroup, Gender))
mean_base
?mean()
mean_base <- pay_clean |>
summarise(mean = round(mean(BasePay), 2),
.by = c(AgeGroup, Gender))
mean_base
mean_base <- pay_clean |>
summarise(mean = round(mean(BasePay), -2),
.by = c(AgeGroup, Gender))
mean_base
mean_base <- pay_clean |>
summarise(mean = mean(BasePay),
.by = c(AgeGroup, Gender))
mean_base
pay_clean |>
summarise(mean = mean(BasePay),
.by = c(AgeGroup, Gender))
pay_clean |>
summarise(mean = round(mean(BasePay), 2),
.by = c(AgeGroup, Gender))
?round*
pay_clean |>
summarise(mean = sigif(mean(BasePay), 2),
.by = c(AgeGroup, Gender))
pay_clean |>
summarise(mean = signif(mean(BasePay), 2),
.by = c(AgeGroup, Gender))
pay_clean |>
summarise(mean = signif(mean(BasePay), -2),
.by = c(AgeGroup, Gender))
pay_clean |>
summarise(mean = mean(BasePay),
.by = c(AgeGroup, Gender))
mean_base <- pay_clean |>
summarise(mean = mean(BasePay),
.by = c(AgeGroup, Gender))
View(mean_base)
mean_base |>
summarise(gap = (mean(Male) - mean(Female)) / mean(Male),
.by = AgeGroup)
