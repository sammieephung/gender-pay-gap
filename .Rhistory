# Load necessary packages through package manager "pacman" ----
if(!require("pacman")) install.packages("pacman")
pacman::p_load(tidyverse, readxl, here)
# Import data set ----
# use here::here() to specify file path relative to project directory
pay_v1 = read_xlsx(path = here::here("data", "PayV1.xlsx"), col_names = T)
# inspect raw data
str(pay_v1)
# Drop any initial NAs ----
sapply(pay_v1, function(x) sum(is.na(x))) # number of NAs in each variable
pay_clean = pay_v1 |> drop_na()
unique(pay_clean$JobTitle)
unique(pay_clean$Gender) # "."
unique(pay_clean$Education)
unique(pay_clean$Dept) # "."
unique(pay_clean$Seniority)
unique(pay_clean$PerfEval) # "10"
## Continuous/Quantitative variables ----
# Age, BasePay, Bonus
# check each variable for non-digits in values
sum(str_detect(pay_clean$BasePay, "\\D"))
str_subset(pay_clean$BasePay, "\\D") # letter
sum(str_detect(pay_clean$Age, "\\D"))
str_subset(pay_clean$Age, "\\D") # "."
sum(str_detect(pay_clean$Bonus, "\\D"))
# Remove all invalid entries ----
pay_clean = pay_clean |>
filter_out(str_detect(BasePay, "\\D") | str_detect(Age, "\\D") | PerfEval == 10 | str_detect(Gender, "\.") | str_detect(Dept, "\."))
# Remove all invalid entries ----
pay_clean = pay_clean |>
filter_out(str_detect(BasePay, "\\D") | str_detect(Age, "\\D") | PerfEval == 10 | str_detect(Gender, "\\.") | str_detect(Dept, "\\."))
# Examine outliers ----
par(nfrow = c(1, 3))
# Examine outliers ----
par(nfrows = c(1, 3))
?par()
# Examine outliers ----
par(mfcol = c(3, 1))
attach(pay_clean)
boxplot(BasePay)
# Examine outliers ----
par(mfrow = c(1, 3))
boxplot(BasePay)
?boxplot
boxplot(pay_clean$BasePay)
# Change all variables into appropriate type based on codebook
str(pay_clean)
pay_clean = pay_clean |>
mutate(JobTitle = as.factor(JobTitle),
Gender = as.factor(Gender), # Female will be ref
Education = factor(Education, levels = c("High School", "College", "Masters", "PhD")),
Dept = as.factor(Dept),
Seniority = factor(Seniority, levels = c("1", "2", "3", "4", "5")),
BasePay = as.numeric(BasePay),
Age = as.numeric(Age),
Bonus = as.numeric(Bonus),
PerfEval = factor(PerfEval, levels = c("1", "2", "3", "4", "5", "6", "7"))
)
# Examine outliers ----
par(mfrow = c(1, 3))
attach(pay_clean)
boxplot(pay_clean$BasePay)
boxplot(BasePay)
boxplot(BasePay)
boxplot(BasePay)
boxplot(BasePay); boxplot(Age); boxplot(Bonus)
boxplot(BasePay); boxplot(Age); boxplot(Bonus)
# Examine outliers ----
par(mfrow = c(1, 3)) # for side-by-side plots
boxplot(BasePay)
boxplot(Age)
boxplot(Bonus)
cbind(max_BasePay = max(BasePay),
max_Age = max(Age),
max_Bonus = max(Bonus))
cbind(mean_BasePay = mean(BasePay),
mean_Age = mean(Age),
mean_Bonus = mean(Bonus))
?filter_out
pacman::p_load(tidyverse, readxl, here, psych)
# Descriptive stats
describe(pay_clean)
# Descriptive stats
describe(pay_clean[, c("BasePay", "Age", "Bonus")])
# remove outliers
filter_out(pay_clean, BasePay == max(BasePay), Age == max(Age), Bonus == max(Bonus))
# remove outliers
pay_clean = filter_out(pay_clean, BasePay == max(BasePay), Age == max(Age), Bonus == max(Bonus))
# remove outliers
pay_clean = pay_clean |>
filter_out(BasePay == max(BasePay), Age == max(Age), Bonus == max(Bonus))
# remove outliers
pay_clean = pay_clean |>
filter_out(BasePay == max(BasePay) | Age == max(Age) | Bonus == max(Bonus))
boxplot(BasePay)
boxplot(Age)
boxplot(Bonus)
attach(pay_clean)
boxplot(BasePay)
boxplot(Age)
boxplot(Bonus)
describe(pay_clean[, c("BasePay", "Age", "Bonus")])
# Load necessary packages through package manager "pacman" ----
if(!require("pacman")) install.packages("pacman")
pacman::p_load(tidyverse, readxl, here, psych)
# Import data set ----
# use here::here() to specify file path relative to project directory
pay_v1 = read_xlsx(path = here::here("data", "PayV1.xlsx"), col_names = T)
# inspect raw data
str(pay_v1)
# Examine and remove NAs ----
sapply(pay_v1, function(x) sum(is.na(x))) # number of NAs in each variable
pay_clean = pay_v1 |> drop_na() # remove NAs
# Examine each variable for invalid entries ----
## Categorical variables ----
# JobTitle, Gender, Education, Dept, Seniority, PerfEval
# list all unique values under each of them
unique(pay_clean$JobTitle)
unique(pay_clean$Gender) # "."
unique(pay_clean$Education)
unique(pay_clean$Dept) # "."
unique(pay_clean$Seniority)
unique(pay_clean$PerfEval) # "10"
## Continuous/Quantitative variables ----
# Age, BasePay, Bonus
# check each variable for non-digits in values
sum(str_detect(pay_clean$BasePay, "\\D"))
str_subset(pay_clean$BasePay, "\\D") # letter
sum(str_detect(pay_clean$Age, "\\D"))
str_subset(pay_clean$Age, "\\D") # "."
sum(str_detect(pay_clean$Bonus, "\\D"))
# Remove all invalid entries ----
pay_clean = pay_clean |>
filter_out(str_detect(BasePay, "\\D") | str_detect(Age, "\\D") | PerfEval == 10 |
str_detect(Gender, "\\.") | str_detect(Dept, "\\."))
# Change all variables into appropriate type based on codebook ----
str(pay_clean)
pay_clean = pay_clean |>
mutate(JobTitle = as.factor(JobTitle),
Gender = as.factor(Gender), # Female will be ref
Education = factor(Education, levels = c("High School", "College", "Masters", "PhD")),
Dept = as.factor(Dept),
Seniority = factor(Seniority, levels = c("1", "2", "3", "4", "5")),
BasePay = as.numeric(BasePay),
Age = as.numeric(Age),
Bonus = as.numeric(Bonus),
PerfEval = factor(PerfEval, levels = c("1", "2", "3", "4", "5"))
)
View(pay_clean)
# Descriptive stats for quantitative variables ----
describe(pay_clean[, c("BasePay", "Age", "Bonus")])
# Frequency tables for categorical variables ----
table(pay_clean$JobTitle)
table(pay_clean$Gender)
?table()
# Frequency tables for categorical variables ----
prop.table(pay_clean$JobTitle)
table(pay_clean)
pacman::p_load(tidyverse, readxl, here, psych, table1, tableone)
??CreateTableOne
# Table 1 Descriptive Statistics ----
tableone::CreateTableOne(data = pay_clean, test = F)
# Table 1 Descriptive Statistics ----
tableone::CreateTableOne(strata = Gender, data = pay_clean, test = F)
# Table 1 Descriptive Statistics ----
tableone::CreateTableOne(strata = "Gender", data = pay_clean, test = F)
# Table 1 Descriptive Statistics ----
tableone::CreateTableOne(vars = c("JobTitle",  "Age", "Education", "Dept",
"Seniority", "BasePay", "Bonus", "PerfEval"),
strata = "Gender", data = pay_clean, test = F)
# Table 1 Descriptive Statistics ----
table1 = tableone::CreateTableOne(vars = c("JobTitle",  "Age", "Education", "Dept",
"Seniority", "BasePay", "Bonus", "PerfEval"),
strata = "Gender", data = pay_clean, test = F)
kableone(table1)
table1::table1(~ JobTitle + Age + Education + Dept +
Seniority + BasePay + Bonus + PerfEval | Gender, data = pay_clean)
# Table 1 Descriptive Statistics ----
table1 = tableone::CreateTableOne(vars = c("JobTitle",  "Age", "Education", "Dept",
"Seniority", "BasePay", "Bonus", "PerfEval"),
strata = "Gender", data = pay_clean, test = F, addOverall = T)
kableone(table1) # html table
# kableone(table1) # html table
print(table1)
?table1
table1::table1(~ JobTitle + Age + Education + Dept +
Seniority + BasePay + Bonus + PerfEval | Gender, data = pay_clean)
# Save cleaned data set to .RData file ----
save(pay_clean, file = here::here("data", "pay_clean.RData"))
